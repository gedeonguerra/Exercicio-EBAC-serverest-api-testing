				{
					"name": "Listar Todos os Usuários",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code é 200\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"Response contém array de usuários\", function () {\r",
									"    var jsonData = pm.response.json();\r",
									"    pm.expect(jsonData.usuarios).to.be.an('array');\r",
									"});\r",
									"\r",
									"pm.test(\"Quantidade de usuários é retornada\", function () {\r",
									"    var jsonData = pm.response.json();\r",
									"    pm.expect(jsonData.quantidade).to.be.a('number');\r",
									"    pm.expect(jsonData.quantidade).to.be.at.least(0);\r",
									"});\r",
									"\r",
									"pm.test(\"Tempo de resposta menor que 300ms\", function () {\r",
									"    pm.expect(pm.response.responseTime).to.be.below(300);\r",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
